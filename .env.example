# ---- World ID ----
WORLD_APP_ID=app_staging_xxx
WORLD_ACTION_ID=fiado-credit-line
WORLD_VERIFY_RP_ID=
WORLD_SIGNER_PRIVATE_KEY=
WORLD_API_BASE=https://developer.worldcoin.org

# ---- Arc / Circle ----
ARC_RPC_URL=
ARC_CHAIN_ID=
DEPLOYER_PRIVATE_KEY=
USDC_ADDRESS=
CREDITLINE_ADDRESS=

# ---- Agent / backend ----
BACKEND_PORT=3001
BACKEND_SIGNER_PRIVATE_KEY=
AGENT_ADDRESS=
POLICY_CONFIDENCE_THRESHOLD=0.85
POLICY_VELOCITY_WINDOW_MS=60000
POLICY_VELOCITY_MAX=5
# Above this amount (USDC) the agent asks the customer a clarifying question first.
POLICY_QUESTION_THRESHOLD=50
# At/under this amount (USDC), credit is auto-granted by rule (no agent reasoning).
POLICY_AUTO_GRANT_THRESHOLD=5
# Per-customer credit limit (USDC). No new credit while a balance is owed (one tab at a time).
POLICY_CREDIT_LIMIT=250
# Model for the headless credit agent (claude CLI alias). Haiku = fast + cheap.
AGENT_MODEL=haiku

# ---- Mandate defaults (signed on Ledger, these are the demo seed values) ----
MANDATE_MAX_PER_TX=250
MANDATE_MAX_TOTAL_OUTSTANDING=5000
MANDATE_TTL_HOURS=6

# ---- Ledger ----
# Ethereum address controlled by the physical Ledger; set as ledgerSigner on deploy.
LEDGER_SIGNER=0x0A41dF8518D7f892Da5F87C85b58A9BB7aFfa6bb
LEDGER_DERIVATION_PATH=44'/60'/0'/0/0
# Set to "speculos" to use the emulator, "device" for the physical Ledger
LEDGER_MODE=device

# ---- Agent relayer (submits autoDisburse / approveAndDisburse on Arc) ----
AGENT_PRIVATE_KEY=

# ---- Demo scaling ----
# UI shows display USDC; on-chain settlement = display / DEMO_SCALE_DIVISOR.
# 1 = real 1:1. e.g. 1000000 = UI 1,500 USDC settles as 0.0015 on-chain (fits faucet).
DEMO_SCALE_DIVISOR=1

# ---- App (Vite frontend, browser-exposed VITE_*) ----
# External World ID app (IDKit). app/.env holds these locally (gitignored).
VITE_WORLD_APP_ID=app_xxx
VITE_WORLD_ACTION=fiado-credit-line
# Dev: leave unset to use the Vite /api proxy. Prod (Vercel): public backend URL
# (e.g. an ngrok https URL during the demo).
# VITE_API_BASE=https://your-backend.ngrok.app
DEMO_MOCK_MODE=false
